#!/bin/sh
set -eu

SRCROOT=$(git rev-parse --show-toplevel)

GITLEAKS=$(mise which gitleaks 2>/dev/null || command -v gitleaks 2>/dev/null || true)
if [ -n "$GITLEAKS" ]; then
  "$GITLEAKS" protect --staged --source "$SRCROOT" -v
fi

if [ -x "$SRCROOT/.nest/bin/swiftformat" ]; then
  SWIFTFORMAT="$SRCROOT/.nest/bin/swiftformat"
else
  SWIFTFORMAT=$(command -v swiftformat) || {
    echo "swiftformat not found. Run: make install-commands (or: brew install swiftformat)"
    exit 1
  }
fi
if [ -x "$SRCROOT/.nest/bin/swiftlint" ]; then
  SWIFTLINT="$SRCROOT/.nest/bin/swiftlint"
else
  SWIFTLINT=$(command -v swiftlint) || {
    echo "swiftlint not found. Run: make install-commands (or: brew install swiftlint)"
    exit 1
  }
fi
if [ -x "$SRCROOT/.nest/bin/my-swift-linter" ]; then
  MY_SWIFT_LINTER="$SRCROOT/.nest/bin/my-swift-linter"
else
  MY_SWIFT_LINTER=$(command -v my-swift-linter) || {
    echo "my-swift-linter not found. Run: make install-commands"
    exit 1
  }
fi

STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -n "$STAGED_SWIFT_FILES" ]; then
  echo "$STAGED_SWIFT_FILES" | xargs "$SWIFTFORMAT" --config "$SRCROOT/.swiftformat"
  echo "$STAGED_SWIFT_FILES" | xargs git add

  ABSOLUTE_FILES=""
  for file in $STAGED_SWIFT_FILES; do
    if [ -f "$SRCROOT/$file" ]; then
      ABSOLUTE_FILES="$ABSOLUTE_FILES $SRCROOT/$file"
    fi
  done

  if [ -n "$ABSOLUTE_FILES" ]; then
    # shellcheck disable=SC2086
    if ! "$SWIFTLINT" lint --config "$SRCROOT/.swiftlint.yml" --force-exclude --strict --quiet --no-cache $ABSOLUTE_FILES; then
      echo ""
      echo "SwiftLint reported issues. Fix them before committing."
      exit 1
    fi
  fi

  if ! (cd "$SRCROOT" && "$MY_SWIFT_LINTER" --config "$SRCROOT/.swift-ast-lint.yml" --no-cache Sources Tests Package.swift); then
    echo ""
    echo "my-swift-linter reported issues. Fix them before committing."
    exit 1
  fi
fi

DOCSYNC="$SRCROOT/.nest/bin/docsync"
if [ -x "$DOCSYNC" ] && [ -f "$SRCROOT/docsync.yml" ]; then
  if ! "$DOCSYNC" check --config "$SRCROOT/docsync.yml" 2>/dev/null; then
    echo ""
    echo "docsync: docs are out of sync. Update docs or run 'docsync update-checksum'."
    exit 1
  fi
fi

exit 0
